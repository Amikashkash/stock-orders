rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users — anyone authenticated can create their own doc (for registration),
    // read/update their own doc, admins can do everything
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
      // Allow admin to list all users
      allow list: if isAdmin();
    }

    // Products — all authenticated users can read and update stock (for picking completion)
    // only admins can create or delete products
    match /products/{sku} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow create, delete: if isAdmin();
    }

    // Orders — all authenticated users can read (needed for picking queue)
    // only the order owner or admin can update/delete
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (isAdmin()
          || resource.data.createdBy == request.auth.uid
          || (request.resource.data.status == 'picked' && resource.data.status in ['pending', 'in-progress']));
      allow delete: if isAuthenticated()
        && (isAdmin() || resource.data.createdBy == request.auth.uid);

      match /orderItems/{itemId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Stock entries — all authenticated users can read; any authenticated can write
    // (picking completion and manual insertions both write here)
    match /stockEntries/{entryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Order number counter — all authenticated users can read/write
    match /counters/{counterId} {
      allow read, write: if isAuthenticated();
    }
  }
}
